# Nevermined — SUBSCRIBER key (not builder key). Must be full key from the app (format: sandbox:<JWT>).
# Get it from https://nevermined.app → API Keys → Global NVM API Keys → + New API Key → Copy Key
NVM_API_KEY=sandbox:your-subscriber-api-key
NVM_ENVIRONMENT=sandbox
NVM_PLAN_ID=seller-plan-id       # The seller's plan you subscribed to
NVM_AGENT_ID=seller-agent-id     # Optional: seller's agent ID

# Seller endpoint — use 3000 for HTTP seller (seller: poetry run python -m src.agent). Do not use 9001; that is for A2A and has no /pricing or /data.
SELLER_URL=http://localhost:3000

# LLM - OpenAI (for local dev with agent.py)
OPENAI_API_KEY=sk-your-key
MODEL_ID=gpt-4o-mini

# LLM - Bedrock (for AgentCore with agent_agentcore.py)
# AWS_REGION=us-west-2
# BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0

# Seller A2A endpoint (for A2A mode)
SELLER_A2A_URL=http://localhost:9000

# Buyer registration server port (for A2A mode)
BUYER_PORT=8000

# Optional: pre-obtained x402 access token for a cheap-plan seller (skip token fetch when set)
# CHEAP_PLAN_ACCESS_TOKEN=eyJ4NDAy...

# Budget limits (optional, 0 = unlimited)
MAX_DAILY_SPEND=100
MAX_PER_REQUEST=10

# RateGenius (marketplace search — optional). Defaults work for the public RateGenius instance.
# Buy credits on plan 97866696... at nevermined.app (3 credits per search).
# RATEGENIUS_URL=https://unsyllabified-wearifully-blaise.ngrok-free.dev
# RATEGENIUS_PLAN_ID=97866696145535066453103713195260098266633201693062554670376824816568438944699
# RATEGENIUS_AGENT_ID=19382499784507691897099813046158899650802606062565712631387582302174094534652

# AgentCore deployment (for web-agentcore mode)
# PORT=8080                                   # Set by AgentCore runtime
# AGENT_URL=https://your-agent.agentcore.aws  # AgentCore public URL
# SELLER_AGENT_ARN=arn:aws:bedrock-agentcore:us-west-2:ACCOUNT:runtime/seller_agent-XXX
